---
// Compact "latest article" row used on the home page index.
import type { PostView } from '../lib/posts';
interface Props {
  post: PostView;
}
const { post } = Astro.props;
---

<a href={post.href} class="post-row">
  <span class="date mono">{post.dateMono}</span>
  <span class="cat" style={`color:${post.catColor};`}>{post.catLabel}</span>
  <span class="title">
    {post.title}
    {post.isDraft && <span class="draft">DRAFT</span>}
  </span>
  <span class="arrow">→</span>
</a>

<style>
  .post-row {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 18px;
    border-top: 1px solid var(--border);
    padding: 16px 6px;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .post-row:hover {
    background: rgba(255, 255, 255, 0.025);
  }
  .date {
    font-size: 12px;
    color: var(--fg-muted);
    flex: none;
    width: 84px;
  }
  .cat {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.03em;
    flex: none;
    width: 62px;
  }
  .title {
    flex: 1;
    min-width: 0;
    font-size: 16px;
    font-weight: 500;
    color: var(--fg);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .draft {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--warning);
    border: 1px solid var(--warning);
    border-radius: 9999px;
    padding: 1px 6px;
    margin-left: 8px;
    vertical-align: middle;
  }
  .arrow {
    color: var(--fg-muted);
    flex: none;
    font-size: 14px;
  }
  @media (max-width: 560px) {
    .date {
      width: 74px;
    }
    .cat {
      display: none;
    }
  }
</style>
