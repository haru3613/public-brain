---
// The full-width article row used on the Writing and Markets list pages.
import type { PostView } from '../lib/posts';
interface Props {
  post: PostView;
}
const { post } = Astro.props;
---

<a href={post.href} class="item" data-category={post.category}>
  <div class="meta">
    <span class="date mono">{post.dateMono}</span>
    <span class="cat" style={`color:${post.catColor};`}>{post.catLabel}</span>
    <span class="read mono">· {post.readTime}</span>
    {post.isDraft && <span class="draft mono">DRAFT</span>}
  </div>
  <h3 class="title">{post.title}</h3>
  <p class="summary">{post.summary}</p>
  {
    post.tags.length > 0 && (
      <div class="tag-row">
        {post.tags.map((tag) => (
          <span class="tag mono">#{tag}</span>
        ))}
      </div>
    )
  }
</a>

<style>
  .item {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 7px;
    border-top: 1px solid var(--border);
    padding: 24px 6px;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .item:hover {
    background: rgba(255, 255, 255, 0.022);
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .date {
    font-size: 12px;
    color: var(--fg-muted);
  }
  .cat {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.03em;
  }
  .read {
    font-size: 11px;
    color: var(--fg-muted);
  }
  .draft {
    font-size: 9px;
    color: var(--warning);
    border: 1px solid var(--warning);
    border-radius: 9999px;
    padding: 1px 7px;
  }
  .title {
    font-family: var(--font-heading);
    font-size: 21px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    color: var(--fg);
  }
  .summary {
    font-size: 15px;
    color: var(--fg-muted);
    line-height: 1.65;
    margin: 0;
    max-width: 72ch;
  }
  .tag-row {
    display: flex;
    gap: 7px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .tag {
    font-size: 11px;
    color: var(--fg-muted);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 9999px;
    padding: 2px 9px;
  }
</style>
